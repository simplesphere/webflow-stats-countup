{
  "buildCommand": "bun run build:embed",
  "outputDirectory": "dist-embed",
  "framework": null,
  "headers": [
    {
      "source": "/stat-counter.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
